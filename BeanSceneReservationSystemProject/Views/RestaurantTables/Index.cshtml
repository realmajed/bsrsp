@model TableManagementViewModel

@{
    ViewData["Title"] = "Tables";
}

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
    <div>
        <h1 class="mb-1">Tables</h1>
        <p class="text-muted mb-0">Manage restaurant areas, table codes, seating capacity, and table availability.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add Table</a>
</div>

<partial name="_TableFloorPlan" model="Model" />

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="border rounded-3 bg-light p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h5 mb-1">Areas</h2>
                    <div class="text-muted small">Group tables by dining space.</div>
                </div>
                <span class="badge rounded-pill text-bg-secondary">@Model.Areas.Count areas</span>
            </div>

            <div class="row row-cols-1 row-cols-md-2 g-3">
                @foreach (var area in Model.Areas)
                {
                    <div class="col">
                        <div class="border rounded-3 bg-white p-3 h-100">
                            <div class="d-flex justify-content-between gap-2">
                                <div>
                                    <div class="fw-bold">@area.AreaName</div>
                                    <div class="text-muted small">@area.RestaurantTables.Count table(s)</div>
                                </div>
                                <div class="d-flex gap-1 align-items-center">
                                    <a asp-action="EditArea" asp-route-id="@area.AreaId" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <form asp-action="DeleteArea" asp-route-id="@area.AreaId" method="post" class="m-0">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <form asp-action="CreateArea" method="post" class="border rounded-3 bg-light p-3 h-100">
            <h2 class="h5 mb-1">Add Area</h2>
            <div class="text-muted small mb-3">Create a new dining area for table assignment.</div>
            <label asp-for="NewArea.AreaName" class="form-label"></label>
            <input asp-for="NewArea.AreaName" name="AreaName" class="form-control" />
            <span asp-validation-for="NewArea.AreaName" class="text-danger"></span>
            <button type="submit" class="btn btn-primary mt-3">Save Area</button>
        </form>
    </div>
</div>

<div class="border rounded-3 bg-light p-3">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-2 align-items-md-center mb-3">
        <div>
            <h2 class="h5 mb-1">Restaurant Tables</h2>
            <div class="text-muted small">Unavailable tables stay visible but cannot be assigned to reservations.</div>
        </div>
        <span class="badge rounded-pill text-bg-success">@Model.Tables.Count tables</span>
    </div>

    @if (!Model.Tables.Any())
    {
        <div class="text-muted text-center border border-2 border-secondary-subtle rounded-3 p-4">No tables have been added yet.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
            @foreach (var table in Model.Tables)
            {
                <div class="col">
                    <div class="border rounded-3 bg-white p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fs-4 fw-bold lh-1">@table.TableCode</div>
                                <div class="text-muted mt-2">@table.Area?.AreaName</div>
                            </div>
                            <span class="badge rounded-pill @(table.IsAvailable ? "text-bg-success" : "text-bg-danger")">
                                @(table.IsAvailable ? "Available" : "Unavailable")
                            </span>
                        </div>
                        <div class="mt-3">
                            <span class="badge text-dark border">@table.Capacity seats</span>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <a asp-action="Edit" asp-route-id="@table.RestaurantTableId" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@table.RestaurantTableId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
