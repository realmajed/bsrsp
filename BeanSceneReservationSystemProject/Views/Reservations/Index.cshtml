@model IEnumerable<BeanSceneReservationSystemProject.Models.Reservation>

@{
    var isMemberReservationsList = ViewData["IsMemberReservationsList"] as bool? == true;
    ViewData["Title"] = isMemberReservationsList ? "Your Reservations" : "Reservations";
    var selectedStatus = ViewData["Status"]?.ToString();
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-primary">Create Reservation</a>
</div>
<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    @* Keep filters as query string values so staff can share or refresh the list. *@
    <div class="col-md-3">
        <label for="search" class="form-label">Search</label>
        <input id="search" name="search" class="form-control" value="@ViewData["Search"]" />
    </div>
    <div class="col-md-2">
        <label for="status" class="form-label">Status</label>
        <select id="status" name="status" class="form-select">
            <option value="">All statuses</option>
            @foreach (var statusOption in Enum.GetValues<ReservationStatus>())
            {
                <option value="@statusOption" selected="@(selectedStatus == statusOption.ToString() ? "selected" : null)">@statusOption</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label for="sittingId" class="form-label">Sitting</label>
        <select id="sittingId" name="sittingId" class="form-select" asp-items="ViewBag.SittingIdFilter">
            <option value="">All sittings</option>
        </select>
    </div>
    <div class="col-md-2">
        <label for="date" class="form-label">Date</label>
        <input id="date" name="date" class="form-control" type="date" value="@ViewData["Date"]" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>
<table class="table table-striped table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Guest</th>
            <th>Sitting</th>
            <th>Start</th>
            <th>Guests</th>
            <th>Source</th>
            <th>Status</th>
            <th>Tables</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.GuestFullName</td>
                <td>@item.Sitting?.SittingType</td>
                <td>@item.StartTime.ToString("g")</td>
                <td>@item.NumberOfGuests</td>
                <td>@item.Source</td>
                <td><span class="badge bg-secondary">@item.Status</span></td>
                <td>@string.Join(", ", item.ReservationTables.Select(rt => rt.RestaurantTable?.TableCode))</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.ReservationId" class="btn btn-sm btn-outline-secondary">Details</a>
                    @* Members can see their bookings but need to contact staff to change them. *@
                    @if (!isMemberReservationsList)
                    {
                        <a asp-action="Edit" asp-route-id="@item.ReservationId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.ReservationId" class="btn btn-sm btn-outline-danger">Delete</a>
                        <form asp-action="SendReminder" asp-route-id="@item.ReservationId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-info">Send Reminder</button>
                        </form>
                    }
                    else
                    {
                        <a asp-action="Edit" asp-route-id="@item.ReservationId" class="btn btn-sm btn-outline-primary cursor-pointer disabled">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.ReservationId" class="btn btn-sm btn-outline-danger cursor-pointer disabled">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
