@model BeanSceneReservationSystemProject.Models.Sitting
@{
    ViewData["Title"] = "Edit Sitting";
    var isMultiDay = (bool)(ViewData["IsMultiDay"] ?? false);
}
<h1>Edit Sitting</h1>
<form asp-action="Edit" method="post" class="card p-4 shadow-sm">
    <input type="hidden" asp-for="SittingId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="SittingType" class="form-label"></label><select asp-for="SittingType" asp-items="Html.GetEnumSelectList<SittingType>()" class="form-select"></select><span asp-validation-for="SittingType" class="text-danger"></span></div>
        <div class="col-md-6"><label asp-for="Capacity" class="form-label"></label><input asp-for="Capacity" class="form-control" /><span asp-validation-for="Capacity" class="text-danger"></span></div>
        <div class="col-md-6">
            <label for="startDate" class="form-label">Start date</label>
            <input id="startDate" name="startDate" type="date" class="form-control" value="@ViewData["StartDate"]" />
            <span asp-validation-for="StartDateTime" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label for="startTime" class="form-label">Start time</label>
            <input id="startTime" name="startTime" type="time" class="form-control" value="@ViewData["StartTime"]" />
        </div>
        <div class="col-md-6 form-check ms-2">
            <input id="isMultiDay" name="isMultiDay" type="checkbox" value="true" class="form-check-input" @(isMultiDay ? "checked" : "") />
            <input type="hidden" name="isMultiDay" value="false" />
            <label for="isMultiDay" class="form-check-label">Multi-day sitting</label>
        </div>
        <div id="endDateField" class="col-md-6">
            <label for="endDate" class="form-label">End date</label>
            <input id="endDate" name="endDate" type="date" class="form-control" value="@ViewData["EndDate"]" />
        </div>
        <div class="col-md-6">
            <label for="endTime" class="form-label">End time</label>
            <input id="endTime" name="endTime" type="time" class="form-control" value="@ViewData["EndTime"]" />
            <span asp-validation-for="EndDateTime" class="text-danger"></span>
        </div>
        <div class="col-md-6 form-check ms-2"><input asp-for="IsClosed" class="form-check-input" /><label asp-for="IsClosed" class="form-check-label"></label></div>
    </div>
    <div class="mt-3"><button class="btn btn-primary" type="submit">Update</button><a asp-action="Index" class="btn btn-secondary">Cancel</a></div>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const multiDay = document.getElementById('isMultiDay');
            const endDateField = document.getElementById('endDateField');
            const endDate = document.getElementById('endDate');
            const startDate = document.getElementById('startDate');

            const updateEndDate = () => {
                endDateField.classList.toggle('d-none', !multiDay.checked);
                if (!multiDay.checked) {
                    endDate.value = startDate.value;
                }
            };

            multiDay.addEventListener('change', updateEndDate);
            startDate.addEventListener('change', () => {
                if (!multiDay.checked) {
                    endDate.value = startDate.value;
                }
            });
            updateEndDate();
        })();
    </script>
}
