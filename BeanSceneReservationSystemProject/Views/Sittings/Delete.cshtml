@model BeanSceneReservationSystemProject.Models.Sitting
@{
    ViewData["Title"] = "Delete Sitting";
}

<h1>Delete Sitting</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this sitting?
</div>

<div class="card p-4 shadow-sm">
    <dl class="row mb-0">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.SittingType)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.SittingType)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.StartDateTime)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.StartDateTime)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EndDateTime)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.EndDateTime)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Capacity)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Capacity)</dd>

        <dt class="col-sm-3">Guests booked</dt>
        <dd class="col-sm-9">@Model.GuestsBooked</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="SittingId" />
    <button type="submit" class="btn btn-danger" disabled="@(Model.Reservations.Any())">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@if (Model.Reservations.Any())
{
    <div class="text-muted small mt-2">
        This sitting has reservation history, so it cannot be deleted. Close it from the edit screen instead.
    </div>
}
