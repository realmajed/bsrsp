# ASP.NET Core reads these as configuration keys using double underscores.
# Do not commit a real .env file with credentials.

Smtp__Server=smtp.example.com
Smtp__Port=587
Smtp__Name=Bean Scene
Smtp__Email=no-reply@example.com
Smtp__User=your-smtp-username
Smtp__Password=your-smtp-password
Smtp__EnableSsl=true
