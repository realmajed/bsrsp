@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            @if (Model.CanUploadProfilePicture)
            {
                <div class="mb-3">
                    <label asp-for="Input.ProfilePicture" class="form-label"></label>
                    <div class="d-flex align-items-center gap-3">
                        @if (!string.IsNullOrWhiteSpace(Model.Input.ProfilePicturePath))
                        {
                            <img src="@Model.Input.ProfilePicturePath" alt="Current profile picture" class="rounded-circle border" style="width: 96px; height: 96px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle border bg-light d-flex align-items-center justify-content-center text-muted" style="width: 96px; height: 96px;">
                                No photo
                            </div>
                        }
                        <div class="flex-grow-1">
                            <input asp-for="Input.ProfilePicture" type="file" accept="image/png,image/jpeg,image/gif,image/webp" class="form-control" />
                            <span asp-validation-for="Input.ProfilePicture" class="text-danger"></span>
                            <div class="form-text">JPG, PNG, GIF or WEBP, up to 2 MB.</div>
                        </div>
                    </div>
                </div>
            }
            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control" placeholder="Please choose your username." disabled />
                <label asp-for="Username" class="form-label"></label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Please enter your phone number."/>
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Role" class="form-control" placeholder="Please choose your username." disabled />
                <label asp-for="Role" class="form-label"></label>
            </div>
            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">Save</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
